# 言語ごとのビルド成果物など「プロジェクト固有」のものは各リポジトリの .gitignore に任せる。

########################################
# Emacs
########################################
# 一時ファイル
\#*#
*~
# ロックファイル
.\#*
# auto-save
auto-save-list/

########################################
# macOS
########################################
.DS_Store
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

########################################
# エディタ / IDE
########################################
# JetBrains (IntelliJ など)
.idea/
# VSCode
.vscode/
# Cursor
.cursor/

########################################
# 汎用
########################################
# 汎用tmpファイル置き場
/usr_tmp
# バックアップファイル
*.bak

########################################
# direnv
########################################
.envrc
.env
.direnv/

########################################
# Python (キャッシュ類)
########################################
__pycache__/
*.py[cod]
.mypy_cache/
.ruff_cache/
.pytest_cache/

########################################
# AI コーディングツール
########################################
**/.claude/settings.local.json
**/.claude.json
