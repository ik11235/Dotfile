{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "autoUpdatesChannel": "stable",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Edit(*)",
      "Write(*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git rev-parse*)",
      "Bash(git branch*)",
      "Bash(git -C * status*)",
      "Bash(git -C * diff*)",
      "Bash(git -C * log*)",
      "Bash(git -C * rev-parse*)",
      "Bash(nix *)",
      "Bash(home-manager *)",
      "Read(/tmp/commit-draft*)",
      "Write(/tmp/commit-draft*)",
      "Create(/tmp/commit-draft*)",
      "mcp__notion__*",
      "mcp__slack__*"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Read(.env*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(npm uninstall *)",
      "Bash(npm remove *)",
      "Bash(psql *)",
      "Bash(mysql *)",
      "Bash(mongod *)",
      "mcp__supabase__execute_sql"
    ]
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70",
    "CLAUDE_CODE_ENABLE_TASKS": "true"
  },
  "model": "claude-opus-4-7",
  "enabledPlugins": {
    "slack@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true
  },
  "language": "ja",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "effortLevel": "xhigh",
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline-command.sh",
    "padding": 1
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"${CLAUDE_PROJECT_DIR:-$PWD}/tasks/lessons.md\"; if [ -f \"$f\" ] && [ -n \"$(find \"$f\" -mmin +60 -print 2>/dev/null)\" ]; then echo '{\"systemMessage\":\"tasks/lessons.md が 60 分以上更新されていません。今回のセッションで学びがあったか確認してください\"}'; fi; exit 0",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
