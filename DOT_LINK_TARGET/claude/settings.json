{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "CLAUDE_CODE_ENABLE_TASKS": "true"
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude Opus 4.7 <noreply@anthropic.com>",
    "pr": "Generated with Claude Code"
  },
  "permissions": {
    "allow": [
      "Bash(git -C * status*)",
      "Bash(git -C * diff*)",
      "Bash(git -C * log*)",
      "Bash(git -C * rev-parse*)",
      "Bash(nix *)",
      "Bash(home-manager *)",
      "Read(/tmp/commit-draft*)",
      "Write(/tmp/commit-draft*)",
      "Create(/tmp/commit-draft*)",
      "mcp__notion__*",
      "mcp__slack__*",
      "mcp__claude_ai_Atlassian__searchJiraIssuesUsingJql",
      "mcp__claude_ai_Google_Calendar__list_events",
      "mcp__claude_ai_Miro__context_explore",
      "mcp__todoist__find-tasks",
      "mcp__todoist__find-tasks-by-date",
      "mcp__todoist__find-projects",
      "mcp__todoist__find-sections",
      "mcp__todoist__find-labels",
      "mcp__todoist__find-filters",
      "mcp__todoist__find-comments",
      "mcp__todoist__find-completed-tasks",
      "mcp__todoist__find-reminders",
      "mcp__todoist__find-activity",
      "mcp__todoist__find-project-collaborators",
      "mcp__todoist__fetch",
      "mcp__todoist__fetch-object",
      "mcp__todoist__get-overview",
      "mcp__todoist__get-productivity-stats",
      "mcp__todoist__get-project-activity-stats",
      "mcp__todoist__get-project-health",
      "mcp__todoist__get-workspace-insights",
      "mcp__todoist__search",
      "mcp__todoist__user-info",
      "mcp__todoist__list-workspaces",
      "mcp__todoist__analyze-project-health"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Read(.env*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials.json)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.key)",
      "Read(**/.ssh/**)",
      "Read(**/*id_rsa*)",
      "Read(**/*id_ed25519*)",
      "Read(**/*id_ecdsa*)",
      "Read(**/*id_dsa*)",
      "Read(**/secrets/**)",
      "Write(.env*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/secrets/**)",
      "Bash(nc *)",
      "Bash(npm uninstall *)",
      "Bash(npm remove *)",
      "Bash(psql *)",
      "Bash(mysql *)",
      "Bash(mongod *)",
      "mcp__supabase__execute_sql"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-opus-4-7",
  "enableAllProjectMcpServers": true,
  "skillOverrides": {
    "best-practice": "user-invocable-only"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"${CLAUDE_PROJECT_DIR:-$PWD}/tasks/lessons.md\"; if [ -f \"$f\" ] && [ -n \"$(find \"$f\" -mmin +60 -print 2>/dev/null)\" ]; then echo '{\"systemMessage\":\"tasks/lessons.md が 60 分以上更新されていません。今回のセッションで学びがあったか確認してください\"}'; fi; exit 0",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$HOME/.claude/skills/best-practice/.last-run\"; if [ ! -f \"$f\" ] || [ -n \"$(find \"$f\" -mtime +14 -print 2>/dev/null)\" ]; then echo '{\"systemMessage\":\"/best-practice によるルール見直しが 2 週間以上行われていません。設定の陳腐化を防ぐため /best-practice の実行を検討してください\"}'; fi; exit 0",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline-command.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true
  },
  "language": "ja",
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "stable",
  "tui": "default",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "preferredNotifChannel": "iterm2",
  "skipAutoPermissionPrompt": true
}
