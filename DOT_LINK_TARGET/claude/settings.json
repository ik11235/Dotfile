{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "CLAUDE_CODE_ENABLE_TASKS": "true",
    "API_TIMEOUT_MS": "1200000",
    "MCP_TIMEOUT": "30000",
    "MCP_TOOL_TIMEOUT": "120000"
  },
  "permissions": {
    "allow": [
      "Bash(git -C * status*)",
      "Bash(git -C * diff*)",
      "Bash(git -C * log*)",
      "Bash(git -C * rev-parse*)",
      "Bash(nix *)",
      "Bash(home-manager *)",
      "Read(/tmp/commit-draft*)",
      "Edit(/tmp/commit-draft*)",
      "mcp__claude_ai_Atlassian__searchJiraIssuesUsingJql",
      "mcp__claude_ai_Atlassian__getAccessibleAtlassianResources",
      "mcp__claude_ai_Atlassian__getJiraIssue",
      "mcp__claude_ai_Google_Calendar__list_events",
      "mcp__claude_ai_Miro__context_explore",
      "mcp__claude_ai_Notion__notion-search",
      "mcp__claude_ai_Notion__notion-fetch",
      "mcp__claude_ai_Notion__notion-query-data-sources",
      "mcp__claude_ai_Slack__slack_search_public_and_private",
      "mcp__todoist__find-tasks",
      "mcp__todoist__find-tasks-by-date",
      "mcp__todoist__find-projects",
      "mcp__todoist__find-sections",
      "mcp__todoist__find-labels",
      "mcp__todoist__find-filters",
      "mcp__todoist__find-comments",
      "mcp__todoist__find-completed-tasks",
      "mcp__todoist__find-reminders",
      "mcp__todoist__find-activity",
      "mcp__todoist__find-project-collaborators",
      "mcp__todoist__fetch",
      "mcp__todoist__fetch-object",
      "mcp__todoist__get-overview",
      "mcp__todoist__get-productivity-stats",
      "mcp__todoist__get-project-activity-stats",
      "mcp__todoist__get-project-health",
      "mcp__todoist__get-workspace-insights",
      "mcp__todoist__search",
      "mcp__todoist__user-info",
      "mcp__todoist__list-workspaces",
      "mcp__todoist__analyze-project-health"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Read(.env*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials.json)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.key)",
      "Read(**/.ssh/**)",
      "Read(**/*id_rsa*)",
      "Read(**/*id_ed25519*)",
      "Read(**/*id_ecdsa*)",
      "Read(**/*id_dsa*)",
      "Read(**/secrets/**)",
      "Read(**/.aws/**)",
      "Read(**/.netrc)",
      "Read(**/.config/gcloud/**)",
      "Read(**/.kube/config)",
      "Edit(.env*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/secrets/**)",
      "Bash(nc *)",
      "Bash(npm uninstall *)",
      "Bash(npm remove *)",
      "Bash(psql *)",
      "Bash(mysql *)",
      "Bash(mongod *)",
      "mcp__supabase__execute_sql"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "enableAllProjectMcpServers": false,
  "skillOverrides": {
    "best-practice": "user-invocable-only"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"${CLAUDE_PROJECT_DIR:-$PWD}/tasks/lessons.md\"; if [ -f \"$f\" ] && [ -n \"$(find \"$f\" -mmin +60 -print 2>/dev/null)\" ]; then echo '{\"systemMessage\":\"tasks/lessons.md が 60 分以上更新されていません。今回のセッションで学びがあったか確認してください\"}'; fi; exit 0",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$HOME/.claude/skills/best-practice/.last-run\"; if [ ! -f \"$f\" ] || [ -n \"$(find \"$f\" -mtime +14 -print 2>/dev/null)\" ]; then echo '{\"systemMessage\":\"/best-practice によるルール見直しが 2 週間以上行われていません。設定の陳腐化を防ぐため /best-practice の実行を検討してください\"}'; fi; exit 0",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "f=\"$HOME/.claude/.fewer-permission-prompts-last-run\"; if [ ! -f \"$f\" ] || [ -n \"$(find \"$f\" -mtime +30 -print 2>/dev/null)\" ]; then echo '{\"systemMessage\":\"/fewer-permission-prompts の実行から30日以上経過しています。allowlist の月次更新を検討してください（実行後: touch ~/.claude/.fewer-permission-prompts-last-run）\"}'; fi; exit 0",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline-command.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "i-have-adhd@i-have-adhd": true
  },
  "extraKnownMarketplaces": {
    "i-have-adhd": {
      "source": {
        "source": "directory",
        "path": "$HOME/ghq/github.com/ayghri/i-have-adhd"
      }
    }
  },
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "autoUpdatesChannel": "stable",
  "tui": "default",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "theme": "auto",
  "preferredNotifChannel": "iterm2"
}
