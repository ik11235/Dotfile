# PATHを最初に設定（以降のツールが依存）
source "${DOTHOME}/.zsh.d/global/path.zsh"
# シェルのコア設定（履歴、補完、オプション）
source "${DOTHOME}/.zsh.d/global/core.zsh"
# プロンプト表示
source "${DOTHOME}/.zsh.d/global/prompt.zsh"
# 外部ツール連携
source "${DOTHOME}/.zsh.d/global/tools.zsh"

case "${OSTYPE}" in
# Mac(Unix)
darwin*)
  # shellcheck source=./zshrc_mac
  source "${DOTHOME}/.zsh.d/zshrc_mac"
  ;;
# Linux
linux*)
  # shellcheck source=./zshrc_linux
  source "${DOTHOME}/.zsh.d/zshrc_linux"
  ;;
esac
